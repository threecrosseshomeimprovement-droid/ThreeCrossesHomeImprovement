<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Three Crosses Home Improvement</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #ffffff;
      color: #333333;
    }

    header {
      background-color: #006400; /* Forest green */
      color: white;
      text-align: center;
      padding: 20px 10px;
    }

    header img {
      max-width: 150px;
      margin-bottom: 10px;
    }

    h1 {
      margin: 0;
      font-size: 28px;
    }

    nav {
      display: flex;
      justify-content: center;
      gap: 15px;
      margin-top: 10px;
    }

    nav a {
      color: white;
      text-decoration: none;
      font-weight: bold;
    }

    section {
      padding: 20px;
    }

    .service-list {
      list-style-type: none;
      padding: 0;
    }

    .service-list li {
      padding: 10px 0;
      border-bottom: 1px solid #ccc;
    }

    footer {
      background-color: #f0f0f0;
      text-align: center;
      padding: 15px;
      font-size: 14px;
    }

    a.contact-link {
      color: #006400;
      text-decoration: none;
      font-weight: bold;
    }

    @media (max-width: 600px) {
      h1 {
        font-size: 24px;
      }

      nav {
        flex-direction: column;
        gap: 8px;
      }
    }
  </style>
</head>
<body>
  <header>
    <img src="logo.png" alt="Three Crosses Home Improvement Logo">
    <h1>Three Crosses Home Improvement</h1>
    <nav>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section id="services">
    <h2>Our Services</h2>
    <ul class="service-list">
      <li>General Home Repairs</li>
      <li>Painting & Staining</li>
      <li>Deck & Fence Work</li>
      <li>Kitchen & Bathroom Remodeling</li>
      <li>Drywall & Carpentry</li>
      <li>Emergency Repairs</li>
    </ul>
  </section>

  <section id="contact">
    <h2>Contact Us</h2>
    <p>📞 Phone: <a class="contact-link" href="tel:9186361683">918-636-1683</a></p>
    <p>📧 Email: <a class="contact-link" href="mailto:threecrosseshomeimprovement@gmail.com">threecrosseshomeimprovement@gmail.com</a></p>
    <p>📍 Based in Sapulpa, OK</p>
  </section>

  <footer>
    &copy; 2026 Three Crosses Home Improvement. All rights reserved.
  </footer>
</body>
</html>